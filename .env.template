# Your cloud tenant URL
TENANT_URL=https://your-tenant.example.com

# API key from your tenant
API_KEY=your_api_key_here

# Optional: enable experimental/predictive tools
# ENABLE_EXPERIMENTAL_TOOLS=true

# Vapi API key (from dashboard.vapi.ai)
VAPI_API_KEY=your_vapi_api_key_here

# Assistant name shown in Vapi dashboard
# VAPI_ASSISTANT_NAME=MCP Voice Assistant

# Knowledgebase ID for documentation search (from your tenant)
# KNOWLEDGEBASE_ID=your_knowledgebase_id_here

# For test_invoke.py: the assistant ID to test against
# ASSISTANT_ID=your_assistant_id_here

# For test_kbs.py: comma-separated id:label pairs
# TEST_KB_IDS=abc-123:My KB,def-456:Other KB

# Override voice tools exposed to Vapi (comma-separated, must match MCP server)
# VOICE_TOOLS=search,describe_app,get_data_model,get_fields,search_knowledgebase_chunks

# --- knowledgebase-mcp usage ---
# To use with knowledgebase-mcp (local semantic search over markdown docs):
# MCP_URL=http://localhost:8000/mcp
# VOICE_TOOLS=search_knowledgebase,list_documents

# Path to MCP server directory (for start.sh / start_mcp.sh)
# MCP_SERVER_DIR=/path/to/mcp-server

# MCP Python module name (the -m argument for uv run)
# MCP_MODULE=your_mcp_module
